# scitex-genai environment variables
# Copy to .env and fill in the values you need. Resolution is lazy: a key is
# only required when you actually invoke the provider that uses it.

# --- Provider API keys (cloud models) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
PERPLEXITY_API_KEY=
LLAMA_API_KEY=

# --- Self-hosted / OpenAI-compatible endpoint ---
# Point GenAI() at a self-hosted model (e.g. a vLLM model behind a LiteLLM
# proxy). These are read only for an unknown/local model name (or when an
# explicit base_url is passed); explicit GenAI(base_url=, api_key=) args win,
# and known provider models are unaffected. Namespaced on purpose — do NOT
# use OPENAI_BASE_URL (the openai SDK auto-reads it and would redirect real
# gpt-* traffic to the proxy).
SCITEX_GENAI_BASE_URL=
SCITEX_GENAI_API_KEY=
