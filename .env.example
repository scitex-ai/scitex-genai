# scitex-genai environment variables
# Copy to .env and fill in the values you need. Resolution is lazy: a key is
# only required when you actually invoke the provider that uses it.

# --- Provider API keys (cloud models) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
PERPLEXITY_API_KEY=
LLAMA_API_KEY=

# --- Self-hosted / OpenAI-compatible endpoint ---
# Point GenAI() at a self-hosted model (e.g. a vLLM model behind a LiteLLM
# proxy). These are read only for an unknown/local model name (or when an
# explicit base_url is passed); explicit GenAI(base_url=, api_key=) args win,
# and known provider models are unaffected. Namespaced on purpose — do NOT
# use OPENAI_BASE_URL (the openai SDK auto-reads it and would redirect real
# gpt-* traffic to the proxy).
SCITEX_GENAI_BASE_URL=
SCITEX_GENAI_API_KEY=

# --- Dispatch backend (experimental, opt-in) ---
# "litellm" routes ANY provider through the single litellm-backed handler
# (one OpenAI-compatible code path). Leave unset (or "default") for the
# classic per-provider dispatch. Explicit GenAI(backend=...) wins over this.
SCITEX_GENAI_BACKEND=

# --- Anthropic-compatible Codex subscription gateway ---
# Path-separated Codex home directories. Each must contain auth.json created
# by `codex login`. The directory name becomes the non-secret account alias.
SCITEX_GENAI_CODEX_HOMES=
# Required inbound key used by Claude Code to authenticate to the local relay.
SCITEX_GENAI_GATEWAY_API_KEY=
# Normally leave this unset; useful only for a compatible test/upstream relay.
SCITEX_GENAI_CODEX_BASE_URL=
